# NextAuth.js Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# GitHub OAuth Configuration
# Create a GitHub OAuth app at https://github.com/settings/developers
# Set the authorization callback URL to: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Admin Configuration
# Set to your GitHub user ID to auto-promote to admin on login
ADMIN_GITHUB_ID=

# Optional local-only auth bypass for development and E2E.
# Never set STACKHATCH_DEV_AUTH=1 in production.
STACKHATCH_DEV_AUTH=0
STACKHATCH_DEV_ROLE=admin

# Server-managed Anthropic configuration. This is not exposed to the browser.
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
