# Runtime database. In production, migrate this file offline during a maintenance window with an
# explicit absolute path; do not run operator commands against an implicit environment default.
DATABASE_URL=file:./data/stackhatch.db

# Public site metadata
NEXT_PUBLIC_SITE_URL=https://stackhatch.io

# Optional privacy-focused analytics. Both values are required at build time to enable Umami.
# With Compose, pass this file through --env-file so the values become Docker build arguments.
NEXT_PUBLIC_UMAMI_SCRIPT_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# NextAuth.js Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here
STACKHATCH_ENCRYPTION_KEY=replace-with-a-separate-encryption-secret

# GitHub OAuth Configuration
# Create a GitHub OAuth app at https://github.com/settings/developers
# Set the authorization callback URL to: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Optional server-side token for higher public GitHub API rate limits
GITHUB_TOKEN=

# Optional local-only auth bypass for development and E2E.
# Never set STACKHATCH_DEV_AUTH=1 in production.
STACKHATCH_DEV_AUTH=0
