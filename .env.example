ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
DATABASE_URL=file:./data/shastack.db

# NextAuth.js Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# GitHub OAuth Configuration
# Create a GitHub OAuth app at https://github.com/settings/developers
# Set the authorization callback URL to: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Admin Configuration
# Set to your GitHub user ID to auto-promote to admin on login
ADMIN_GITHUB_ID=

# Local development auth bypass. Never enable in production.
STACKHATCH_DEV_AUTH=0
STACKHATCH_DEV_ROLE=admin

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (create these in your Stripe dashboard)
STRIPE_PRICE_PRO_MONTHLY=price_your_pro_monthly_price_id_here
STRIPE_PRICE_PRO_ANNUAL=price_your_pro_annual_price_id_here
STRIPE_PRICE_TEAM5_MONTHLY=price_your_team5_monthly_price_id_here
STRIPE_PRICE_TEAM5_ANNUAL=price_your_team5_annual_price_id_here
STRIPE_PRICE_TEAM15_MONTHLY=price_your_team15_monthly_price_id_here
STRIPE_PRICE_TEAM15_ANNUAL=price_your_team15_annual_price_id_here
