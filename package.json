{
  "name": "stackhatch",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.9.7",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "esbuild": "^0.25.12",
    "postcss": "^8.5.13"
  },
  "scripts": {
    "dev": "STACKHATCH_DEV_AUTH=${STACKHATCH_DEV_AUTH:-1} next dev",
    "build": "npm run build:operators && next build",
    "build:operators": "esbuild scripts/manage-account.ts scripts/migrate-database.ts --bundle --platform=node --format=cjs --target=node22 --outdir=operator --out-extension:.js=.cjs --external:better-sqlite3",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:real-auth": "REAL_AUTH_SMOKE=1 PLAYWRIGHT_DEV_AUTH=0 playwright test e2e/real-auth-logout.test.ts",
    "screenshots:capture": "node scripts/capture-observatory-screenshots.mjs",
    "test:coverage": "vitest run --coverage",
    "eval:repositories": "tsx scripts/evaluate-public-repositories.ts",
    "account:manage": "tsx scripts/manage-account.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate-database.ts",
    "db:migrate:offline": "tsx scripts/migrate-database.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "better-sqlite3": "^12.9.0",
    "dagre": "^0.8.5",
    "drizzle-orm": "^0.45.2",
    "html-to-image": "^1.11.13",
    "idb": "^8.0.3",
    "lucide-react": "^0.575.0",
    "next": "^16.2.10",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "reactflow": "^11.11.4",
    "yaml": "^2.8.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dagre": "^0.7.53",
    "@types/node": "^25.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.2.10",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^27.0.1",
    "postcss": "^8.5.13",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
